{
  "name": "flight-bun",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "react": "experimental",
    "react-dom": "experimental",
    "react-server-dom-bun": "experimental"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1"
  },
  "scripts": {
    "predev": "cp -r ../../build/oss-experimental/* ./node_modules/",
    "dev": "bun run dev:region & sleep 1 && bun run dev:global",
    "dev:region": "NODE_ENV=development bun run --conditions=react-server server/region.js",
    "dev:global": "NODE_ENV=development bun run server/global.js",
    "build": "bun run scripts/build.js",
    "test": "bun run test:e2e",
    "test:e2e": "playwright test"
  }
}
